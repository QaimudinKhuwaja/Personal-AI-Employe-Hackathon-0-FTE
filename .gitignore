# AI Employee .gitignore
# ===========================================
# Environment variables (NEVER commit credentials)
# ===========================================
.env
.env.local
.env.*.local
.env.*.private
*.env

# ===========================================
# Python
# ===========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.spec

# ===========================================
# Virtual environments
# ===========================================
venv/
ENV/
env/
.venv/
.pytest_cache/

# ===========================================
# IDE & Editor
# ===========================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ===========================================
# Logs
# ===========================================
*.log
logs/

# ===========================================
# Cache files
# ===========================================
.processed_files.cache
.processed_*.cache
*.cache

# ===========================================
# Obsidian
# ===========================================
.obsidian/

# ===========================================
# Temporary files
# ===========================================
tmp/
temp/
*.tmp

# ===========================================
# Test files
# ===========================================
.coverage
htmlcov/
.tox/

# ===========================================
# Credentials & Secrets (NEVER commit)
# ===========================================
credentials.json
credentials/
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
secret.json
secret/
api_key.json
api_keys.json
*.secret

# ===========================================
# OAuth & API Tokens
# ===========================================
token.json
tokens.json
*.token
*.tokens
oauth/
oauth-*.json
access_token.json
refresh_token.json

# ===========================================
# Session files
# ===========================================
whatsapp_session/
browser_session/
.linkedin_session/
*.session
session/
sessions/

# ===========================================
# MCP server state
# ===========================================
.mcp-state/

# ===========================================
# Node.js
# ===========================================
node_modules/
npm-debug.log
yarn-error.log

# ===========================================
# Docker
# ===========================================
*.pid
*.seed
*.pid.lock

# ===========================================
# Backup files
# ===========================================
*.bak
*.backup
*.old

# ===========================================
# Database files (may contain sensitive data)
# ===========================================
*.db
*.sqlite
*.sqlite3

# ===========================================
# Odoo specific (may contain credentials)
# ===========================================
odoo.conf.local
*.odoo.session

# ===========================================
# Gmail/Google tokens
# ===========================================
.gmail_token.json
google_credentials.json
google_token.json

