# AI Employee Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!

# ===========================================
# General Settings
# ===========================================

# Vault path (optional, can also be passed as command line argument)
VAULT_PATH=/path/to/your/AI_Employee_Vault

# Dry run mode (prevents actual external actions)
# Set to "true" during development and testing
DRY_RUN=true

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ===========================================
# Claude Code Settings
# ===========================================

# Claude Code model (optional, defaults to latest)
# CLAUDE_MODEL=claude-4-5-opus

# Claude API key (if using API directly)
# CLAUDE_API_KEY=your_api_key_here

# ===========================================
# Gmail API Credentials (for Gmail Watcher)
# ===========================================
# Required for Silver/Gold tier Gmail integration

GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REDIRECT_URI=http://localhost:8080
GMAIL_CREDENTIALS_PATH=/path/to/gmail_credentials.json

# ===========================================
# WhatsApp Settings (for WhatsApp Watcher)
# ===========================================
# Required for Silver/Gold tier WhatsApp integration

WHATSAPP_SESSION_PATH=/path/to/whatsapp/session
WHATSAPP_PHONE=your_phone_number_here

# ===========================================
# Banking/Finance API
# ===========================================
# Required for Gold tier accounting integration

BANK_API_URL=your_bank_api_url
BANK_API_TOKEN=your_bank_token_here
BANK_API_KEY=your_bank_key_here

# ===========================================
# Odoo ERP Settings (for Gold/Platinum tier)
# ===========================================
# Required for Odoo accounting integration

ODOO_URL=http://localhost:8069
ODOO_DATABASE=your_database_name
ODOO_USERNAME=your_odoo_username
ODOO_API_KEY=your_odoo_api_key

# ===========================================
# Social Media APIs (for Silver/Gold tier)
# ===========================================
# Required for automated social media posting

# LinkedIn API (Official REST API - Recommended)
# Get from: https://www.linkedin.com/developers/
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_PERSON_URN=urn:li:person:YOUR_ID_HERE
# See LINKEDIN_API_SETUP_GUIDE.md for detailed setup instructions

# Twitter/X (API v2 - Required for Gold Tier)
# Get from: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your_bearer_token_here
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_token_secret

# Facebook
FACEBOOK_APP_ID=2462264600873199
FACEBOOK_APP_SECRET=5c64845d7c696a6bbf937cc7029f1164
