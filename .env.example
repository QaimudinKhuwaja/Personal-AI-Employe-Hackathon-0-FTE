# ===========================================
# Security Settings
# ===========================================

# Maximum actions per hour (rate limiting)
MAX_EMAILS_PER_HOUR=10
MAX_PAYMENTS_PER_HOUR=3
MAX_SOCIAL_POSTS_PER_HOUR=5

# Approval thresholds (in USD)
AUTO_APPROVE_PAYMENT_LIMIT=50
REQUIRE_APPROVAL_PAYMENT_LIMIT=100

# ===========================================
# Notification Settings
# ===========================================

# Email for critical alerts
ALERT_EMAIL=your_email@example.com

# Webhook URL for notifications (optional)
ALERT_WEBHOOK_URL=

# ===========================================
# Development/Testing
# ===========================================

# Test mode flag
TEST_MODE=false

# Verbose logging
VERBOSE=false
